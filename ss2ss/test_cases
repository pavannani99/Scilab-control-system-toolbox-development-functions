# Test Case 3:

A = [1 2 3; 4 5 6; 7 8 9];
B = [1; 2; 3];
C = [-1 0 1];
D = 0;

[T, E] = spec(A);

original_system = syslin("c", A, B, C, D);
transformed_system = ss2ss(original_system, T);
retransformed_system = ss2ss(transformed_system, inv(T));

disp("Original A matrix:");
disp(original_system.A);
disp("Retransformed A matrix:");
disp(retransformed_system.A);
disp("Original B matrix:");
disp(original_system.B);
disp("Retransformed B matrix:");
disp(retransformed_system.B);
disp("Original C matrix:");
disp(original_system.C);
disp("Retransformed C matrix:");
disp(retransformed_system.C);
disp("Original D matrix:");
